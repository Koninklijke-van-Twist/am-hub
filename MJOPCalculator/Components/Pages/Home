@page "/"
@attribute [Authorize]
@using MJOP.Calculator.Models
@using MJOP.Calculator.Services
@using Microsoft.AspNetCore.Authorization
@rendermode InteractiveServer
@inject EquipmentModelService ModelService
@inject IJSRuntime JS

<div class="container mt-5">
    <h1 class="mb-4">Equipmentmodellen Beheren</h1>
    
    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5>Nieuw Model</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Merk</label>
                        <input type="text" class="form-control" @bind="newModel.Brand" placeholder="bijv. Perkins" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Model Naam</label>
                        <input type="text" class="form-control" @bind="newModel.ModelName" placeholder="bijv. 3012 TAG3a" />
                    </div>
                    
                    <button class="btn btn-success w-100" @onclick="SaveModel">
                        Model Toevoegen
                    </button>
                </div>
            </div>
        </div>
        
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5>Beschikbare Modellen</h5>
                </div>
                <div class="card-body">
                    @if (models != null && models.Count > 0)
                    {
                        <div class="list-group">
                            @foreach (var model in models)
                            {
                                <div class="list-group-item" @key="model.Id" @onclick="() => EditModel(model)">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div >
                                            <h6 class="mb-1">@model.Brand - @model.ModelName</h6>
                                            
                                        </div>
                                        <div>
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteModel(model.Id)">
                                                Verwijder
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Geen modellen gevonden.</p>
                    }
                </div>
            </div>
        </div>
    </div>
    
    @if (selectedModel != null)
    {
        <div class="card mt-4">
            <div class="card-header bg-primary text-white">
                <h5>@selectedModel.Brand - @selectedModel.ModelName</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Onderhoudstaak</th>
                                <th>Prijs (€)</th>
                                <th>Frequentie</th>
                                <th>Interval (in jaren)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in maintenanceItems)
                            {
                                var hideFrequencyAndInterval =
                                    item.Equals("\"0\" Inspectie", StringComparison.OrdinalIgnoreCase) ||
                                    item.Equals("Proefdraaien", StringComparison.OrdinalIgnoreCase);

                                <tr>
                                    <td>@item</td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm"
                                            @bind="editCosts[item]"
                                            placeholder="Standaard prijs gebruiken" />
                                    </td>

                                    <td>
                                        @if (!hideFrequencyAndInterval)
                                        {
                                            <input type="number" class="form-control form-control-sm"
                                                @bind="editFrequency[item]"
                                                placeholder="Standaard frequentie gebruiken" />
                                        }
                                    </td>

                                    <td>
                                        @if (!hideFrequencyAndInterval)
                                        {
                                            <input type="number" class="form-control form-control-sm"
                                                @bind="editInterval[item]"
                                                placeholder="Standaard interval gebruiken" />
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-success" @onclick="SaveAll">
                        opslaan
                    </button>

                    <button class="btn btn-secondary" @onclick="CancelEdit">
                        Klaar
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<EquipmentModel> models = new();
    private EquipmentModel newModel = new();
    private EquipmentModel? selectedModel;
    private Dictionary<string, decimal> editCosts = new();
    private Dictionary<string, decimal> editFrequency = new();
    private Dictionary<string, int> editInterval = new();
    private static readonly List<string> maintenanceItems = new()
    {
        "\"0\" Inspectie",
        "Jaarlijks Onderhoud",
        "Halfjaarlijks Onderhoud",
        "Proefdraaien",
        "Brandstoftank Controle",
        "Smeerolie Analyse",
        "Brandstofanalyse",
        "Koelmedium Analyse",
        "Storingsdienst",
        "Belasten Loadbank",
        "Scios Inspectie",
        "E-Inspectie",
        "Waterslangen",
        "Accu's",
        "Injectoren",
        "Partiële Revisie"
    };

    protected override void OnInitialized()
    {
        LoadModels();
    }

    private void LoadModels()
    {
        models = ModelService.GetAllModels();
    }

    private void SaveModel()
    {
        if (!string.IsNullOrWhiteSpace(newModel.Brand) && !string.IsNullOrWhiteSpace(newModel.ModelName))
        {
            ModelService.AddModel(new EquipmentModel
            {
                Brand = newModel.Brand,
                ModelName = newModel.ModelName,
                CustomCosts = new Dictionary<string, decimal>(),
                CustomFrequencies = new Dictionary<string, decimal>
                {
                    { "\"0\" Inspectie", 1 },
                    { "Jaarlijks Onderhoud", 1 },
                    { "Halfjaarlijks Onderhoud", 1 },
                    { "Proefdraaien", 0 },
                    { "Brandstoftank Controle", 1 },
                    { "Smeerolie Analyse", 1 },
                    { "Brandstofanalyse", 1 },
                    { "Koelmedium Analyse", 1 },
                    { "Storingsdienst", 1 },
                    { "Belasten Loadbank", 1 },
                    { "Scios Inspectie", 1 },
                    { "E-Inspectie", 1 },
                    { "Waterslangen", 1 },
                    { "Accu's", 1 },
                    { "Injectoren", 1 },
                    { "Partiële Revisie", 1 }
                },
                CustomInterval = new Dictionary<string, int>
                {
                    { "\"0\" Inspectie", 1 },
                    { "Jaarlijks Onderhoud", 1 },
                    { "Halfjaarlijks Onderhoud", 1 },
                    { "Proefdraaien", 1 },
                    { "Brandstoftank Controle", 1 },
                    { "Smeerolie Analyse", 1 },
                    { "Brandstofanalyse", 1 },
                    { "Koelmedium Analyse", 1 },
                    { "Storingsdienst", 1 },
                    { "Belasten Loadbank", 1 },
                    { "Scios Inspectie", 4 },
                    { "E-Inspectie", 4 },
                    { "Waterslangen", 4 },
                    { "Accu's", 4 },
                    { "Injectoren", 8 },
                    { "Partiële Revisie", 20 }
                }
            });

            newModel = new();
            LoadModels();
        }
    }

    private void EditModel(EquipmentModel model)
    {
        selectedModel = model;
        editCosts = new Dictionary<string, decimal>(
            maintenanceItems.ToDictionary(
                item => item, 
                item => selectedModel.CustomCosts.ContainsKey(item) ? selectedModel.CustomCosts[item] : 0
            )
        );
        editFrequency = new Dictionary<string, decimal>(
            maintenanceItems.ToDictionary(
                item => item,
                item => selectedModel.CustomFrequencies.ContainsKey(item) ? selectedModel.CustomFrequencies[item] : 0
            )
        );
        editInterval = new Dictionary<string, int>(
            maintenanceItems.ToDictionary(
                item => item,
                item => selectedModel.CustomInterval.ContainsKey(item) ? selectedModel.CustomInterval[item] : 0
            )
        );
    }

    private void SaveAll()
    {
        SaveAllCosts();
        SaveAllFrequencies();
        SaveAllIntervals();
    }
    
    private void SaveAllCosts()
    {
        if (selectedModel != null)
        {
            var updatedCosts = editCosts
                .Where(x => x.Value > 0)
                .ToDictionary(x => x.Key, x => x.Value);

            selectedModel.CustomCosts = updatedCosts;

            ModelService.UpdateModel(selectedModel);

            // Reload voor sync
            selectedModel = ModelService.GetModel(selectedModel.Id);

            // Lijst ook opnieuw laden zodat overzicht direct klopt
            LoadModels();
        }
    }

    private void SaveAllFrequencies()
    {
        if (selectedModel != null)
        {
            var updatedFrequencies = editFrequency
                .Where(x => x.Value > 0)
                .ToDictionary(x => x.Key, x => x.Value);

            selectedModel.CustomFrequencies = updatedFrequencies;

            ModelService.UpdateModel(selectedModel);

            // Reload voor sync
            selectedModel = ModelService.GetModel(selectedModel.Id);

            // Lijst ook opnieuw laden zodat overzicht direct klopt
            LoadModels();
        }
    }

    private void SaveAllIntervals()
    {
        if (selectedModel != null)
        {
            var updatedIntervals = editInterval
                .Where(x => x.Value > 0)
                .ToDictionary(x => x.Key, x => x.Value);

            selectedModel.CustomInterval = updatedIntervals;

            ModelService.UpdateModel(selectedModel);

            selectedModel = null;

            // Lijst ook opnieuw laden zodat overzicht direct klopt
            LoadModels();

            
        }
    }

    

    
    private async Task DeleteModel(int id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Wil je dit echt verwijderen?");

        if (confirmed)
        {
            ModelService.DeleteModel(id);
            selectedModel = null;
            LoadModels();
        }
    }


    private void CancelEdit()
    {
        selectedModel = null;
    }
}
