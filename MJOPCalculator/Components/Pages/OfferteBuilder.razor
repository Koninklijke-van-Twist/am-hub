@page "/offertes"
@attribute [Authorize]
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using System.Text.Json
@using MJOP.Calculator.Models.BusinessCentral

@inject IJSRuntime JS
@inject BusinessCentralApiService BusinessCentralApiService
@inject PdfExportService PdfExportService

<div class="quote-page">

    <div class="quote-header">
       
    </div>

    <div class="card p-4 shadow-sm mb-4">
        <div class="row align-items-end">
            <div class="col-md-8">
                <label class="form-label">Offertenummer</label>
                <input class="form-control" @bind="configurationNo" placeholder="Bijv. SQ12604147" />
            </div>

            <div class="col-md-4 mt-3 mt-md-0">
                <button class="btn btn-primary w-100" @onclick="LoadConfigurationDataAsync" disabled="@isLoading">
                    @(isLoading ? "Laden..." : "Offerte ophalen")
                </button>
            </div>
        </div>

        @if (hasSearched && !string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger mt-3 mb-0">
                @error
            </div>
        }
    </div>

    @if (hasSearched && components.Any() && taskTypes.Any())
    {
        <div class="quote-grid">

            <div class="quote-main">

                <div class="quote-info-row">
                    <div class="d-flex align-items-center gap-2">
                <h3 class="mb-0">Offerte @configurationNo</h3>

                @if (hasSearched && components.Any())
                {
                    <span class="badge bg-primary-subtle text-primary">Concept</span>
                }
            </div>

            <div class="text-muted small mt-1">
                Aangemaakt op Placeholder
                door Placeholder
            </div>

                    <div class="quote-card customer-card">
                        <div class="card-title-row">
                            <span class="card-icon">▣</span>
                            <h5>Klantgegevens</h5>
                        </div>

                        <div class="customer-content">
                            

                            <div>
                                <h6>@(string.IsNullOrWhiteSpace(quoteDetails.CustomerName) ? "Klantnaam placeholder B.V." : quoteDetails.CustomerName)</h6>
                                <div class="text-muted small">
                                    Klantnummer: placeholder<br />
                                    placeholder<br />
                                    1234 AB placeholder
                                </div>
                            </div>

                            <div class="customer-contact">
                                <div class="info-line">
                                    <strong>Contactpersoon</strong><br />
                                    @(string.IsNullOrWhiteSpace(quoteDetails.ContactPerson) ? "Contactpersoon placeholder" : quoteDetails.ContactPerson)
                                </div>

                                <div class="info-line">
                                    <strong>E-mail</strong><br />
                                    @(string.IsNullOrWhiteSpace(quoteDetails.Email) ? "email@placeholder.nl" : quoteDetails.Email)
                                </div>

                                <div class="info-line">
                                    <strong>Telefoon</strong><br />
                                    +31 12 34 56 78 9
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="quote-card offer-info-card">
                        <div class="card-title-row">
                            <span class="card-icon">i</span>
                            <h5>Offerte informatie</h5>
                        </div>

                        <div class="details-list">
                            <div>
                                <span>Offertenummer</span>
                                <strong>@(string.IsNullOrWhiteSpace(quoteDetails.QuoteNo) ? configurationNo : quoteDetails.QuoteNo)</strong>
                            </div>
                            <div>
                                <span>Status</span>
                                <strong><span class="badge bg-primary-subtle text-primary">placeholder</span></strong>
                            </div>
                            <div>
                                <span>Geldigheid</span>
                                <strong>30 dagen</strong>
                            </div>
                            <div>
                                <span>Startdatum</span>
                                <strong>placeholder</strong>
                            </div>
                            <div>
                                <span>Einddatum</span>
                                <strong>placeholder</strong>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="quote-card mt-4">
                    <div class="section-header">
                        <h5>Componenten & werkzaamheden</h5>

                        
                    </div>

                    <div class="table-responsive">
                        <table class="table quote-lines-table">
                            <thead>
                                <tr>
                                    <th>Taak</th>

                                    @foreach (var component in components)
                                    {
                                        <th>@component.ComponentNo</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var taskType in taskTypes)
                                {
                                    <tr>
                                        <td>
                                            <strong>@taskType</strong>
                                        </td>

                                        @foreach (var component in components)
                                        {
                                            var task = component.ComponentTasks
                                                .FirstOrDefault(t => t.Type == taskType);

                                            <td>
                                                @if (task?.Price != null)
                                                {
                                                    @:€ @task.Price.Value.ToString("N2", new System.Globalization.CultureInfo("nl-NL"))
                                                }
                                                else
                                                {
                                                    @:-
                                                }
                                            </td>
                                        }
                                    </tr>
                                }

                                <tr class="total-row">
                                    <td><strong>Totaal</strong></td>

                                    @foreach (var component in components)
                                    {
                                        <td>
                                            <strong>
                                                € @component.TotalPrice.ToString("N2", new System.Globalization.CultureInfo("nl-NL"))
                                            </strong>
                                        </td>
                                    }
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    
                </div>

                <div class="bottom-cards">
                    
                    <div class="quote-card">
                        <div class="section-header">
                            <h5>Bijlagen</h5>
                            
                        </div>

                        <div class="attachment-box">
                            <span class="pdf-icon">PDF</span>
                            <div>
                                <strong>Algemene_voorwaarden_KVT_2024.pdf</strong><br />
                                <span class="text-muted small">PDF • 248 KB</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <div class="quote-sidebar">

                <div>
                    @if (hasSearched && components.Any() && taskTypes.Any())
                    {
                        <button class="btn btn-outline-primary" @onclick="PrintPdf">
                            Preview PDF
                        </button>

                        <button class="btn btn-primary" @onclick="DownloadPdf">
                            Genereer PDF
                        </button>
                    }
                </div>

                <div class="quote-card mt-4">
                    <h5>Offerte samenvatting</h5>

                    <div class="summary-line">
                        <span>Aantal componenten</span>
                        <strong>@(components.Count())</strong>
                    </div>

                    <div class="summary-line">
                        <span>aantal taken</span>
                        <strong></strong>
                    </div>

                    <hr />

                    <div class="summary-total">
                        <span>Totaalbedrag</span>
                        <strong>
                            € @( (components.Sum(c => c.TotalPrice)).ToString("N2", new System.Globalization.CultureInfo("nl-NL")) )
                        </strong>
                    </div>

                    
                </div>

                

            </div>

        </div>
    }

    @if (hasSearched &&
        string.IsNullOrWhiteSpace(error) &&
        !isLoading &&
        (!components.Any() || !taskTypes.Any()))
    {
        <div class="alert alert-warning mt-3">
            Er zijn geen gegevens gevonden voor dit offertenummer.
        </div>
    }

</div>
            



@code {
    private string contextUserName = "Lars Lissenberg";
    private string configurationNo = "SQ12604147";
    private string result = "";
    private string error = "";

    private bool hasSearched = false;
    private bool isLoading = false;

    private QuoteDetailsDto quoteDetails = new();
    private List<Component> components = new();
    private List<string> taskTypes = new();

    private List<ConfigurationRuleDto> configurationRules = new();
    private List<ConfigurationRuleDetailDto> configurationRulesDetails = new();

    private async Task LoadConfigurationDataAsync()
    {
        try
        {
            hasSearched = true;
            isLoading = true;
            error = "";
            result = "";

            components = new();
            taskTypes = new();
            configurationRules = new();
            configurationRulesDetails = new();

            await GetConfigurationRulesAsync();
            await GetConfigurationRulesDetailsAsync();
            await GetQuoteDetailsAsync();

            AttachComponentNosToConfigurationRules();
            BuildComponents();
        }
        catch (Exception ex)
        {
            components = new();
            taskTypes = new();
            configurationRules = new();
            configurationRulesDetails = new();

            result = "";
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GetConfigurationRulesAsync()
    {
        var json = await BusinessCentralApiService.GetBCFilteredDataAsync(
            "ConfigurationRules",
            $"Configuration_No eq '{configurationNo}' and Selected eq true and Job_Task_Type eq 'Posting'");

        result = json;

        var options = new JsonSerializerOptions
        {
            PropertyNameCaseInsensitive = true
        };

        var response = JsonSerializer.Deserialize<ODataResponse<ConfigurationRuleDto>>(json, options);

        configurationRules = response?.Value ?? new List<ConfigurationRuleDto>();
    }

    private async Task GetConfigurationRulesDetailsAsync()
    {
        var json = await BusinessCentralApiService.GetBCFilteredDataAsync(
            "ConfigurationRulesDetails",
            $"Configuration_No eq '{configurationNo}'");

        result = json;

        var options = new JsonSerializerOptions
        {
            PropertyNameCaseInsensitive = true
        };

        var response = JsonSerializer.Deserialize<ODataResponse<ConfigurationRuleDetailDto>>(json, options);

        configurationRulesDetails = response?.Value ?? new List<ConfigurationRuleDetailDto>();
    }

    private async Task GetQuoteDetailsAsync()
    {
        var json = await BusinessCentralApiService.GetBCFilteredDataAsync(
            "SalesQuote",
            $"No eq '{configurationNo}'");

        result = json;

        var options = new JsonSerializerOptions
        {
            PropertyNameCaseInsensitive = true
        };

        var response = JsonSerializer.Deserialize<ODataResponse<QuoteDetailsDto>>(json, options);

        quoteDetails = response?.Value.FirstOrDefault() ?? new QuoteDetailsDto();
    }

    private void AttachComponentNosToConfigurationRules()
    {
        foreach (var rule in configurationRules)
        {
            rule.ComponentNos = configurationRulesDetails
                .Where(detail => detail.ConfigurationLineNo == rule.LineNo)
                .Select(detail => detail.ComponentNo)
                .ToList();
        }
    }

    private void BuildComponents()
    {
        components = configurationRulesDetails
            .GroupBy(detail => detail.ComponentNo)
            .Select(group =>
            {
                var component = new Component
                {
                    ComponentNo = group.Key
                };

                var lineNumbersForThisComponent = group
                    .Select(x => x.ConfigurationLineNo)
                    .Distinct()
                    .ToList();

                component.ComponentTasks = configurationRules
                    .Where(rule => lineNumbersForThisComponent.Contains(rule.LineNo))
                    .OrderBy(rule => rule.LineNo)
                    .Select(rule => new ComponentTask
                    {
                        Type = rule.ItemNo,
                        Description = rule.Description,
                        Price = rule.UnitPrice > 0 ? rule.UnitPrice : null
                    })
                    .ToList();

                return component;
            })
            .OrderBy(c => c.ComponentNo)
            .ToList();

        taskTypes = components
            .SelectMany(c => c.ComponentTasks)
            .Select(t => t.Type)
            .Distinct()
            .ToList();
    }

    private async Task PrintPdf()
    {
        if (!components.Any() || !taskTypes.Any())
        {
            error = "Haal eerst configuratiegegevens op.";
            return;
        }

        var html = PdfExportService.BuildQuoteHtml(quoteDetails, components, taskTypes);
        await JS.InvokeVoidAsync("exportHtmlToPrint", html);
    }

    private async Task DownloadPdf()
    {
        if (!components.Any() || !taskTypes.Any())
        {
            error = "Haal eerst configuratiegegevens op.";
            return;
        }

        var html = PdfExportService.BuildQuoteHtml(quoteDetails, components, taskTypes);
        await JS.InvokeVoidAsync("exportHtmlToDownload", html, $"Offerte_{configurationNo}.pdf");
    }
}